# ─────────────────────────────────────────────────────────────
# Hotel Benizia — PRODUCTION .env  (WhoGoHost shared cPanel)
# Rename this file to ".env" on the server and fill in the ⬅️ values.
# ─────────────────────────────────────────────────────────────

APP_NAME="Hotel Benizia"
APP_ENV=production
# A key is pre-generated for you. You may keep it, or run `php artisan key:generate`.
APP_KEY=base64:7zVqK/ymvluXuQ5OE+Mr77/Mj7i0YHUm46g0TT+3e/M=
APP_DEBUG=false
APP_URL=https://hotelbenizia.ng          # ⬅️ your live domain (https)

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_MAINTENANCE_DRIVER=file

# ── Logging ──
LOG_CHANNEL=stack
LOG_LEVEL=error

# ── Database (create these in cPanel → MySQL Databases) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_cpanel_db_name          # ⬅️ e.g. benizia_hotel
DB_USERNAME=your_cpanel_db_user          # ⬅️ e.g. benizia_admin
DB_PASSWORD=your_cpanel_db_password      # ⬅️ the DB user password

# ── Sessions / cache / queue (file/db are safe on shared hosting) ──
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# ── Mail (WhoGoHost email account for booking notifications) ──
# In cPanel → Email Accounts, create e.g. booking@hotelbenizia.ng, then:
MAIL_MAILER=smtp
MAIL_HOST=mail.hotelbenizia.ng           # ⬅️ WhoGoHost outgoing mail server
MAIL_PORT=465
MAIL_USERNAME=booking@hotelbenizia.ng    # ⬅️ the email account
MAIL_PASSWORD=your_email_password        # ⬅️ that account's password
MAIL_ENCRYPTION=ssl                      # ssl for 465, or tls for 587
MAIL_FROM_ADDRESS="booking@hotelbenizia.ng"
MAIL_FROM_NAME="${APP_NAME}"

# ── Payments (add real Paystack keys only when going live with cards) ──
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=NGN

# ── Misc ──
FILESYSTEM_DISK=local
VITE_APP_NAME="${APP_NAME}"
